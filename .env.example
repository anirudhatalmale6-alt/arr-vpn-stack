###############################################################################
#  ARR Stack — Environment Variables
#  Copy this file to .env and fill in your values:
#    cp .env.example .env
###############################################################################

# ── PIA VPN Credentials ─────────────────────────────────────────────────────
PIA_USER=your_pia_username
PIA_PASS=your_pia_password
PIA_REGION=Netherlands                  # See: https://github.com/qdm12/gluetun-wiki/blob/main/setup/providers/private-internet-access.md

# ── System ───────────────────────────────────────────────────────────────────
PUID=1000                               # Your Linux user ID (run: id -u)
PGID=1000                               # Your Linux group ID (run: id -g)
TZ=Etc/UTC                              # Your timezone (e.g., America/New_York)

# ── Paths ────────────────────────────────────────────────────────────────────
DOWNLOADS_PATH=./downloads              # Where torrents are downloaded
MEDIA_PATH=./media                      # Root media folder (movies/tv/music subdirs)

# ── Ports (change only if you have conflicts) ────────────────────────────────
QBIT_WEBUI_PORT=8080                    # qBittorrent Web UI
QBIT_PORT=6881                          # qBittorrent torrent traffic port
PROWLARR_PORT=9696                      # Prowlarr Web UI
RADARR_PORT=7878                        # Radarr Web UI
JELLYFIN_PORT=8096                      # Jellyfin Web UI
JELLYSEERR_PORT=5055                    # Jellyseerr Web UI
